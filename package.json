{
  "name": "@chouchiu/markdown",
  "version": "2.0.0",
  "description": "Framework-agnostic Markdown renderer — GFM, syntax highlighting, GitHub Alerts, math. Ships rehype plugins (Astro, VitePress, unified) + React components.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "import": "./dist/plugins/index.js",
      "require": "./dist/plugins/index.cjs"
    },
    "./elements": {
      "types": "./dist/elements/index.d.ts",
      "import": "./dist/elements/index.js",
      "require": "./dist/elements/index.cjs"
    },
    "./styles.css": "./dist/styles/markdown.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/styles/markdown.css",
    "dist/elements/index.js",
    "dist/elements/index.cjs"
  ],
  "scripts": {
    "build": "bun run build:js && bun run build:types && bun run build:css",
    "prepublishOnly": "bun run build",
    "build:js": "tsup",
    "build:types": "tsc --emitDeclarationOnly --outDir dist",
    "build:css": "mkdir -p dist/styles && cp src/styles/markdown.css dist/styles/markdown.css",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src",
    "format": "biome format ./src --write"
  },
  "peerDependencies": {
    "katex": "^0.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "peerDependenciesMeta": {
    "katex": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "prismjs": "^1.30.0",
    "react-markdown": "^10.1.0",
    "rehype-github-alerts": "^4.2.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "markdown",
    "react",
    "astro",
    "rehype",
    "remark",
    "gfm",
    "syntax-highlighting",
    "katex",
    "math",
    "renderer",
    "unified"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChouChiu/markdown"
  }
}
